{
  "name": "design-token-pipeline",
  "version": "1.0.0",
  "description": "A working design token system: Figma variables → Style Dictionary → platform-ready CSS and JS tokens.",
  "author": "Tom DeLuca",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "dev": "npm run build:tokens && vite",
    "build": "npm run build:tokens && vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint \"src/**/*.ts\" \"scripts/**/*.mjs\" \"config/**/*.mjs\"",
    "lint": "npm run lint:css && npm run lint:js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "lucide": "^1.8.0",
    "prettier": "^3.8.3",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10"
  }
}
