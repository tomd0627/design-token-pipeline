{
  "name": "design-token-pipeline",
  "version": "1.0.0",
  "description": "A working design token system: Figma variables → Style Dictionary → platform-ready CSS and JS tokens.",
  "author": "Tom DeLuca",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "dev": "npm run build:tokens && vite",
    "build": "npm run build:tokens && vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint \"src/**/*.ts\" \"scripts/**/*.mjs\" \"config/**/*.mjs\"",
    "lint": "npm run lint:css && npm run lint:js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@fontsource/inter": "^5.0.0",
    "@tokens-studio/sd-transforms": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lucide": "^0.468.0",
    "prettier": "^3.3.0",
    "style-dictionary": "^4.1.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
